# Production Environment Variables Example
# Copy this to .env.production and fill in your values

# Required API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
API_TOKEN=your_secure_api_token_here
ROUNDTABLE_OPERATOR_TOKEN=your_roundtable_operator_token_here

# Optional API Keys (for fallback or specific features)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Optional actor-specific LLM overrides
# OPENROUTER_MODEL_CHINA=deepseek/deepseek-chat-v3-0324
# OPENROUTER_MODEL_US=openai/gpt-4.1-mini
# OPENROUTER_MODEL_EU=mistralai/mistral-large-2411

# Optional actor-specific image routing
# IMAGE_PROVIDER_CHINA=siliconflow
# IMAGE_MODEL_CHINA=Kwai-Kolors/Kolors
# IMAGE_FALLBACK_MODEL_CHINA=flux
# IMAGE_PROVIDER_US=openai
# IMAGE_MODEL_US=gpt-image-1
# IMAGE_FALLBACK_MODEL_US=flux
# IMAGE_PROVIDER_EU=together
# IMAGE_MODEL_EU=black-forest-labs/FLUX.1-schnell-Free
# IMAGE_FALLBACK_MODEL_EU=flux

# Database (Railway/Render will provide DATABASE_URL automatically)
# For local testing with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/aicoldwar

# Production flag
PRODUCTION=true

# CORS Origins (comma-separated if multiple)
ALLOWED_ORIGINS=https://aicoldwar.lovable.app,https://*.lovable.app

# Optional: Audio generation service
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# TTS_SERVICE=elevenlabs
